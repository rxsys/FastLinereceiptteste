rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Recibos enviados via LINE bot (qualquer origem autenticada ou pública de webhook)
    match /owners/{ownerId}/expenses/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Carteira do usuário LINE — créditos/adiantamentos
    match /owners/{ownerId}/wallet/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Avatares e perfis
    match /owners/{ownerId}/avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bloquear qualquer outra leitura/escrita
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
