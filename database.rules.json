{
  "rules": {
    ".read": true,
    ".write": true,
    "users": {
      ".indexOn": ["ownerId"]
    },
    "owner": {
      ".indexOn": ["stripeCustomerId"]
    },
    "owner_data": {
      "$ownerId": {
        "invites": {
          ".indexOn": ["hash"]
        },
        "expenses": {
          ".indexOn": ["date", "amount", "userId", "status"]
        }
      }
    },
    "line_api_pool": {
      ".indexOn": ["ownerId", "status"]
    },
    "audit_logs": {
      "$ownerId": {
        ".indexOn": ["timestamp"]
      }
    }
  }
}
